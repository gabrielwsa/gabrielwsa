---
import GitHub from "./icons/GitHub.astro";
import Link from "./icons/Link.astro";
import LinkButton from "./LinkButton.astro";
import React from "./icons/React.astro";
import { projects } from "@/data/portfolio";

const TAGS = {
  REACT: {
    name: "React",
    icon: React,
  },
};

const tagMap = {
  React: TAGS.REACT,
};
---

<div class="grid gap-6">
  {
    projects.map(
      ({ image, title, eyebrow, description, tags, link, github }, index) => (
        <article class="panel-surface group overflow-hidden rounded-[2rem]">
          <div class="grid gap-6 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)]">
            <div class="p-3 sm:p-4">
              <div class="relative h-full min-h-[260px] overflow-hidden rounded-[1.5rem] border border-white/50 bg-slate-950 dark:border-white/10">
                <img
                  alt={`Vista previa de ${title}`}
                  class="h-full w-full object-cover"
                  loading="lazy"
                  src={image}
                />
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950/75 via-slate-950/10 to-transparent" />
              </div>
            </div>

            <div class="flex flex-col justify-between gap-6 p-6 sm:p-8">
              <div>
                <span class="section-kicker">{eyebrow}</span>
                <h3 class="mt-4 text-2xl font-semibold tracking-tight text-[var(--text-primary)] sm:text-3xl">
                  {title}
                </h3>
                <p class="mt-4 max-w-xl text-base leading-7 text-[var(--text-secondary)]">
                  {description}
                </p>
              </div>

              <div class="flex flex-wrap gap-2">
                {tags.map((tagName) => {
                  const tag = tagMap[tagName];

                  return (
                    <span class="inline-flex items-center gap-x-2 rounded-full border border-[var(--accent-border)] bg-white/60 px-3 py-1.5 text-xs font-medium text-[var(--text-primary)] dark:bg-white/5">
                      <tag.icon class="size-4 text-[var(--accent-strong)]" />
                      {tag.name}
                    </span>
                  );
                })}
              </div>

              <div class="flex flex-wrap gap-3">
                {github && (
                  <LinkButton href={github}>
                    <GitHub class="size-5" />
                    GitHub
                  </LinkButton>
                )}
                {link && (
                  <LinkButton
                    href={link}
                    class="border-[var(--accent-border)] bg-[var(--accent-soft)] text-[var(--accent-strong)] hover:border-[var(--accent-strong)] hover:bg-[var(--accent-strong)] hover:text-slate-950 dark:hover:text-slate-950"
                  >
                    <Link class="size-4" />
                    Sitio web
                  </LinkButton>
                )}
              </div>
            </div>
          </div>
        </article>
      ),
    )
  }
</div>
