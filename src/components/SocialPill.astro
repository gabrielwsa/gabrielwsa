---
const {
  href,
  class: className = "",
  target = typeof href === "string" && href.startsWith("http") ? "_blank" : undefined,
  rel = target === "_blank" ? "noopener noreferrer" : undefined,
  ...rest
} = Astro.props
---

<a
  {...rest}
  href={href}
  target={target}
  rel={rel}
  role="link"
  class={`inline-flex max-w-fit items-center justify-center gap-2 rounded-full border border-white/50 bg-white/80 px-4 py-2.5 text-sm font-medium text-slate-900 shadow-[0_14px_32px_-24px_rgba(15,23,42,0.6)] transition-colors duration-300 hover:border-[var(--accent-border)] hover:bg-white hover:text-[var(--accent-strong)] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--accent-strong)] focus-visible:ring-offset-2 focus-visible:ring-offset-transparent dark:border-white/10 dark:bg-slate-900/80 dark:text-slate-100 dark:hover:bg-slate-950 ${className}`}
>
  <slot />
</a>
