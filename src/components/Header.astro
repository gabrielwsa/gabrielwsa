---
import ThemeToggle from "./ThemeToggle.astro"

const navItems = [
  {
    title: "Inicio",
    label: "inicio",
    url: "/#inicio",
  },
  {
    title: "Experiencia",
    label: "experiencia",
    url: "/#experiencia",
  },
  {
    title: "Proyectos",
    label: "proyectos",
    url: "/#proyectos",
  },
  {
    title: "Certificaciones",
    label: "certificados",
    url: "/#certificados",
  },
  {
    title: "Sobre mí",
    label: "sobre-mi",
    url: "/#sobre-mi",
  },
  {
    title: "Contacto",
    label: "contacto",
    url: "mailto:gabrielsilvadearaujo45@gmail.com",
  },
]
---

<header class="fixed inset-x-0 top-0 z-50 px-4 pt-4 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-6xl">
    <nav class="panel-surface flex items-center justify-between rounded-full px-3 py-2.5 text-sm font-medium text-[var(--text-secondary)]">
      <a
        href="/#inicio"
        class="inline-flex items-center gap-3 rounded-full px-2 py-1 text-[var(--text-primary)] transition-colors duration-300"
        aria-label="Ir al inicio"
      >
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-slate-900 text-sm font-semibold tracking-[0.2em] text-white dark:bg-white dark:text-slate-950">
          GW
        </span>
        <span class="hidden sm:flex sm:flex-col sm:leading-tight">
          <strong class="text-sm font-semibold text-[var(--text-primary)]">Gabriel W. Silva</strong>
          <span class="text-xs text-[var(--text-muted)]">Full Stack Developer</span>
        </span>
      </a>

      <div class="hidden items-center gap-1 md:flex">
        {
          navItems.map((link) => (
            <a
              class="nav-link rounded-full px-4 py-2 transition-colors duration-300 hover:text-[var(--accent-strong)]"
              data-nav-label={link.label}
              aria-label={link.label}
              href={link.url}
            >
              {link.title}
            </a>
          ))
        }
      </div>

      <div class="flex items-center gap-2">
        <ThemeToggle />
        <button
          id="mobile-menu-button"
          class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/40 bg-white/70 text-[var(--text-primary)] transition-colors duration-300 hover:border-[var(--accent-border)] hover:text-[var(--accent-strong)] dark:border-white/10 dark:bg-slate-900/70 md:hidden"
          aria-label="Abrir menu"
          aria-expanded="false"
          aria-controls="nav-menu"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7h16M4 12h16M4 17h16"></path>
          </svg>
        </button>
      </div>
    </nav>

    <div id="nav-backdrop" class="nav-backdrop md:hidden"></div>
    <div id="nav-menu" class="panel-surface nav-menu md:hidden">
      <div class="flex flex-col gap-1 p-3">
        {
          navItems.map((link) => (
            <a
              class="nav-link rounded-2xl px-4 py-3 text-base transition-colors duration-300 hover:text-[var(--accent-strong)]"
              data-nav-label={link.label}
              aria-label={link.label}
              href={link.url}
            >
              {link.title}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</header>

<script>
  type HeaderWindow = Window & typeof globalThis & {
    __gabrielHeaderCleanup?: () => void
  }

  const headerWindow = window as HeaderWindow

  const setupHeader = () => {
    headerWindow.__gabrielHeaderCleanup?.()

    const sections = [...document.querySelectorAll<HTMLElement>("main section[id]")]
    const navLinks = [...document.querySelectorAll<HTMLAnchorElement>(".nav-link")]
    const mobileMenuButton = document.getElementById("mobile-menu-button")
    const navMenu = document.getElementById("nav-menu")
    const navBackdrop = document.getElementById("nav-backdrop")
    const body = document.body

    if (!mobileMenuButton || !navMenu || !navBackdrop) {
      return
    }

    const setMenuOpen = (isOpen: boolean) => {
      navMenu.classList.toggle("is-open", isOpen)
      navBackdrop.classList.toggle("is-open", isOpen)
      mobileMenuButton.setAttribute("aria-expanded", String(isOpen))
      body.classList.toggle("overflow-hidden", isOpen)
    }

    const setActiveLink = (id: string) => {
      navLinks.forEach((link) => {
        link.dataset.active = link.getAttribute("data-nav-label") === id ? "true" : "false"
      })
    }

    const onButtonClick = () => {
      setMenuOpen(!navMenu.classList.contains("is-open"))
    }

    const onBackdropClick = () => setMenuOpen(false)
    const onResize = () => {
      if (window.innerWidth >= 768) {
        setMenuOpen(false)
      }
    }

    mobileMenuButton.addEventListener("click", onButtonClick)
    navBackdrop.addEventListener("click", onBackdropClick)
    window.addEventListener("resize", onResize)
    const linkCleanup = navLinks.map((link) => {
      const onLinkClick = () => setMenuOpen(false)
      link.addEventListener("click", onLinkClick)
      return () => link.removeEventListener("click", onLinkClick)
    })

    let observer: IntersectionObserver | undefined

    if (sections.length > 0) {
      observer = new IntersectionObserver(
        (entries) => {
          const visibleSection = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0]

          if (visibleSection) {
            setActiveLink(visibleSection.target.id)
          }
        },
        {
          rootMargin: "-20% 0px -55% 0px",
          threshold: [0.2, 0.35, 0.6],
        }
      )

      const activeObserver = observer
      sections.forEach((section) => activeObserver.observe(section))
      setActiveLink(sections[0].id)
    }

    headerWindow.__gabrielHeaderCleanup = () => {
      mobileMenuButton.removeEventListener("click", onButtonClick)
      navBackdrop.removeEventListener("click", onBackdropClick)
      window.removeEventListener("resize", onResize)
      linkCleanup.forEach((cleanup) => cleanup())
      observer?.disconnect()
    }
  }

  setupHeader()
  document.addEventListener("astro:page-load", setupHeader)
</script>

<style>
  .nav-menu {
    position: fixed;
    inset-inline: 1rem;
    top: 5.5rem;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-0.75rem);
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
  }

  .nav-menu.is-open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .nav-backdrop {
    position: fixed;
    inset: 0;
    display: block;
    opacity: 0;
    pointer-events: none;
    background: rgba(2, 6, 23, 0.4);
    backdrop-filter: blur(8px);
    transition: opacity 0.3s ease;
  }

  .nav-backdrop.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .nav-link[data-active="true"] {
    color: var(--accent-strong);
    background: var(--accent-soft);
  }
</style>
